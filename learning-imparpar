import java.util.Scanner;

public class Main {
    public static void main(String[] args) throws InterruptedException {

            Scanner sc = new Scanner(System.in);
            System.out.println("Digite seu nome:");
            String name = sc.nextLine();
            System.out.println("Show, calma...");
            Thread.sleep(2500);
            System.out.println("Que nome massa " + name);
            Thread.sleep(2500);
            System.out.println("Agora digite um numero ou 0 para sair:");


        while(true){

            int str = sc.nextInt();

            if (str == 0) {
                System.out.println("Encerrando...");
                System.out.println("Até mais " + name);
                break;
            }

            if (str % 2!= 0){
                System.out.println("O resultado é impar " + name);
            }else {
                System.out.println("O resultado é par " + name);
            }

            System.out.println("Parabéns, continue testando ");
        }
        sc.close();
    }
}
